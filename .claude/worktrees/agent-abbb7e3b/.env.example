# Copy this file to `.env` (same folder) and fill in the values.
# `.env` is gitignored and never shipped.
# Both variables are read at BUILD time by Vite - rebuild after changing them.

# --- Contact form -------------------------------------------------------------
# Web3Forms is a free form-to-email relay. Sign up at https://web3forms.com,
# create an access key tied to your inbox (info@nasseralaligroup.com), then
# paste the key below. Submissions arrive as email; no backend or database
# needed.
VITE_WEB3FORMS_KEY=paste-your-web3forms-access-key-here

# --- AI chat assistant --------------------------------------------------------
# URL of the deployed chat endpoint (Cloudflare Worker, or any serverless
# function you host). See README-CHATBOT.md for one-command deploy.
# Leave blank until the worker is deployed - the chat button will show a
# graceful "assistant temporarily unavailable" state.
VITE_CHAT_API_URL=
