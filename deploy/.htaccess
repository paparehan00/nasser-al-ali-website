# Apache / cPanel shared hosting - React SPA rewrite
# Copy this file into the DocumentRoot (same folder as index.html).

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve real files/folders as-is (assets, images, etc.)
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else -> serve index.html so React Router can handle it
  RewriteRule . /index.html [L]
</IfModule>

# Long-cache all hashed build assets (Vite emits content-hashed filenames)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp                  "access plus 1 year"
  ExpiresByType image/png                   "access plus 1 year"
  ExpiresByType image/jpeg                  "access plus 1 year"
  ExpiresByType video/mp4                   "access plus 1 year"
  ExpiresByType video/webm                  "access plus 1 year"
  ExpiresByType text/css                    "access plus 1 year"
  ExpiresByType application/javascript      "access plus 1 year"
  ExpiresByType application/font-woff2      "access plus 1 year"
  ExpiresByType text/html                   "access plus 0 seconds"
</IfModule>

# Basic gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml
</IfModule>

# Serve WebP with correct content-type on hosts that don't know it
AddType image/webp .webp
