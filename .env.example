# Copy this file to `.env` (same folder) and fill in the values.
# `.env` is gitignored and never shipped.

# --- Client build-time variables (Vite) ---------------------------------------
# These are baked into the frontend bundle at build time. Do NOT put secrets here.

# AI chat assistant: URL of the deployed Cloudflare Worker.
# Leave blank until the worker is deployed.
VITE_CHAT_API_URL=

# --- Server: auth & session ---------------------------------------------------
# Required. Generate a strong random value: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Optional (default 43200 = 12 h)
JWT_TTL_SECONDS=43200

# --- Server: database ---------------------------------------------------------
# Optional. Defaults to ./data/app.db relative to server/
DB_PATH=

# --- Server: admin seed credentials ------------------------------------------
# Only used on first boot to create the initial admin user.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Server: email (Nodemailer + Gmail SMTP) ----------------------------------
# The Gmail account must have 2-Step Verification enabled and use an App Password.
# To generate an App Password: Google Account → Security → 2-Step Verification → App Passwords.
# Never commit the real password.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=leadsnasseralalienterprises@gmail.com
SMTP_PASS=

# Display name shown in the "From" field of outgoing emails.
MAIL_FROM_NAME=Nasser Al Ali Enterprises

# Admin inbox: receives a notification for every new consultation booking.
NOTIFY_EMAIL=rehanmiya7411@gmail.com

# --- Server: AI translation (Groq) -------------------------------------------
# Used by the admin CMS to auto-translate EN → AR on save.
# Get a free key at console.groq.com.
GROQ_API_KEY=

# --- Server: CORS origins -----------------------------------------------------
# Comma-separated list of allowed client origins (production domain goes here).
CLIENT_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:4173
