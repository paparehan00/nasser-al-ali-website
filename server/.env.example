# --- Runtime ---
NODE_ENV=development
PORT=4000

# --- Origins / cookies ---
# Comma-separated origin(s) the browser will be calling from. In prod this is
# the deployed site's origin (e.g. https://nasseralaligroup.com).
CLIENT_ORIGIN=http://localhost:5173

# --- Database ---
DB_PATH=./data/app.db

# --- Uploads ---
# Where processed images are written. In production, point this at a
# persistent volume (Railway: mount a volume at /data and use /data/uploads).
UPLOAD_ROOT=./uploads

# --- Auth ---
# 64+ random chars. Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
# JWT lifetime in seconds (default 12h)
JWT_TTL_SECONDS=43200

# --- Seed admin (used only on first `npm run db:seed`) ---
# The seeded user is forced to change their password on first login.
ADMIN_EMAIL=admin@nasseralaligroup.com
ADMIN_PASSWORD=change-me-strong-temporary
